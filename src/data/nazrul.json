{
    "author": "কাজী নজরুল ইসলাম",
    "slug": "kazi-nazrul-islam",
    "bio": "বাংলাদেশের জাতীয় কবি, বিদ্রোহী কবি হিসেবে পরিচিত।",
    "quotes": [
      { "id": "nazrul-001", "text": "আমি চিরবিদ্রোহী বীর—বিশ্ব ছাড়ায়ে উঠিয়াছি একা।", "category": "বিদ্রোহ" },
      { "id": "nazrul-002", "text": "মানুষের চেয়ে বড় কিছু নাই, নহে কিছু মহীয়ান।", "category": "মানবতা" },
      { "id": "nazrul-003", "text": "গাহি সাম্যের গান—মানুষের চেয়ে বড় কিছু নাই।", "category": "সমতা" },
      { "id": "nazrul-004", "text": "আমি ঝঞ্ঝা, আমি ঘূর্ণি, আমি পথ-সমুদ্রের ঢেউ।", "category": "বিদ্রোহ" },
      { "id": "nazrul-005", "text": "আমি আগুন, আমি দহন, আমি দুর্বার।", "category": "বিদ্রোহ" },
      { "id": "nazrul-006", "text": "সত্যের পথে যারা চলে, তারাই প্রকৃত মানুষ।", "category": "নৈতিকতা" },
      { "id": "nazrul-007", "text": "ভালোবাসাই মানুষের শ্রেষ্ঠ শক্তি।", "category": "ভালোবাসা" },
      { "id": "nazrul-008", "text": "ধর্ম যার যার, উৎসব সবার।", "category": "সম্প্রীতি" },
      { "id": "nazrul-009", "text": "অন্যায়ের বিরুদ্ধে বিদ্রোহ করা ন্যায়ের কাজ।", "category": "বিদ্রোহ" },
      { "id": "nazrul-010", "text": "মানুষকে ভালোবাসাই ধর্ম।", "category": "মানবতা" },
  
      { "id": "nazrul-011", "text": "আমি চির উন্নত শির।", "category": "আত্মবিশ্বাস" },
      { "id": "nazrul-012", "text": "আমি প্রেমের, আমি বিদ্রোহের, আমি মানবতার কবি।", "category": "মানবতা" },
      { "id": "nazrul-013", "text": "অন্যায় সহ্য করা অন্যায় করার সমান।", "category": "ন্যায়" },
      { "id": "nazrul-014", "text": "ভালোবাসা ছাড়া জীবন শূন্য।", "category": "ভালোবাসা" },
      { "id": "nazrul-015", "text": "আমি ঝড়, আমি তুফান, আমি দুর্বার।", "category": "বিদ্রোহ" },
      { "id": "nazrul-016", "text": "মানুষের মাঝে ভেদাভেদ করা পাপ।", "category": "সমতা" },
      { "id": "nazrul-017", "text": "সাহসী হও, অন্যায়ের বিরুদ্ধে দাঁড়াও।", "category": "প্রেরণা" },
      { "id": "nazrul-018", "text": "মানবতার সেবা করাই প্রকৃত ধর্ম।", "category": "মানবতা" },
      { "id": "nazrul-019", "text": "আমি শান্তি চাই, ন্যায় চাই।", "category": "ন্যায়" },
      { "id": "nazrul-020", "text": "শক্তিই সত্যকে প্রতিষ্ঠিত করে।", "category": "প্রেরণা" },
  
      { "id": "nazrul-021", "text": "দুর্বলতা পাপ, সাহসই শক্তি।", "category": "প্রেরণা" },
      { "id": "nazrul-022", "text": "মানুষের মাঝে ভালোবাসা ছড়াও।", "category": "ভালোবাসা" },
      { "id": "nazrul-023", "text": "আমি বিদ্রোহী, আমি অবিনাশী।", "category": "বিদ্রোহ" },
      { "id": "nazrul-024", "text": "ন্যায়ের পথে চলাই জীবনের লক্ষ্য।", "category": "ন্যায়" },
      { "id": "nazrul-025", "text": "ভালোবাসা মানুষের হৃদয়কে জয় করে।", "category": "ভালোবাসা" },
      { "id": "nazrul-026", "text": "আমি শক্তি, আমি সাহস, আমি অগ্নি।", "category": "বিদ্রোহ" },
      { "id": "nazrul-027", "text": "মানুষের মাঝে সমতা প্রতিষ্ঠা করো।", "category": "সমতা" },
      { "id": "nazrul-028", "text": "অন্যায়ের বিরুদ্ধে প্রতিবাদ করো।", "category": "বিদ্রোহ" },
      { "id": "nazrul-029", "text": "সত্য সবসময় বিজয়ী হয়।", "category": "নৈতিকতা" },
      { "id": "nazrul-030", "text": "আমি মুক্তির গান গাই।", "category": "স্বাধীনতা" },
  
      { "id": "nazrul-031", "text": "মানুষকে সম্মান করো, মানবতা রক্ষা করো।", "category": "মানবতা" },
      { "id": "nazrul-032", "text": "সাহসীদের জন্যই বিজয়।", "category": "প্রেরণা" },
      { "id": "nazrul-033", "text": "ভালোবাসা দিয়ে পৃথিবী বদলানো যায়।", "category": "ভালোবাসা" },
      { "id": "nazrul-034", "text": "আমি অন্যায়ের বিরুদ্ধে অগ্নি।", "category": "বিদ্রোহ" },
      { "id": "nazrul-035", "text": "মানুষের কল্যাণে কাজ করো।", "category": "মানবতা" },
      { "id": "nazrul-036", "text": "স্বাধীনতা মানুষের অধিকার।", "category": "স্বাধীনতা" },
      { "id": "nazrul-037", "text": "ন্যায় প্রতিষ্ঠাই জীবনের সার্থকতা।", "category": "ন্যায়" },
      { "id": "nazrul-038", "text": "মানুষের মাঝে ভ্রাতৃত্ব গড়ে তোলো।", "category": "সম্প্রীতি" },
      { "id": "nazrul-039", "text": "আমি প্রেম, আমি শক্তি, আমি মানবতা।", "category": "মানবতা" },
      { "id": "nazrul-040", "text": "সত্যের জন্য সংগ্রাম করো।", "category": "প্রেরণা" },
  
      { "id": "nazrul-041", "text": "অন্যায়ের বিরুদ্ধে রুখে দাঁড়াও।", "category": "বিদ্রোহ" },
      { "id": "nazrul-042", "text": "মানুষই মানুষের জন্য।", "category": "মানবতা" },
      { "id": "nazrul-043", "text": "ভালোবাসাই শান্তির পথ।", "category": "ভালোবাসা" },
      { "id": "nazrul-044", "text": "সাহস হারিয়ো না, এগিয়ে যাও।", "category": "প্রেরণা" },
      { "id": "nazrul-045", "text": "সমতা ছাড়া শান্তি আসে না।", "category": "সমতা" },
      { "id": "nazrul-046", "text": "মানুষের সেবা করাই মহৎ কাজ।", "category": "মানবতা" },
      { "id": "nazrul-047", "text": "সত্যের জন্য জীবন দাও।", "category": "প্রেরণা" },
      { "id": "nazrul-048", "text": "আমি বিদ্রোহী, আমি মুক্ত।", "category": "বিদ্রোহ" },
      { "id": "nazrul-049", "text": "ভালোবাসা দিয়ে ঘৃণা জয় করো।", "category": "ভালোবাসা" },
      { "id": "nazrul-050", "text": "মানবতাই সবচেয়ে বড় ধর্ম।", "category": "মানবতা" }
    ]
  }