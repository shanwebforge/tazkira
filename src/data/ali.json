{
  "author": "হযরত আলী (রা.)",
  "slug": "hazrat-ali",
  "bio": "ইসলামের চতুর্থ খলিফা, মহান সাহাবি ও জ্ঞানী ব্যক্তিত্ব।",
  "quotes": [
    { "id": "ali-001", "text": "মানুষ তার জ্ঞানের শত্রু।", "category": "জ্ঞান" },
    { "id": "ali-002", "text": "নীরবতা হলো জ্ঞানীর সর্বোত্তম উত্তর।", "category": "জ্ঞান" },
    { "id": "ali-003", "text": "যে নিজেকে চিনতে পারে, সে তার প্রভুকে চিনতে পারে।", "category": "ইমান" },
    { "id": "ali-004", "text": "ধৈর্য দুই প্রকার—বিপদে ধৈর্য এবং পাপ থেকে বিরত থাকার ধৈর্য।", "category": "ধৈর্য" },
    { "id": "ali-005", "text": "জ্ঞান সম্পদের চেয়ে উত্তম, কারণ জ্ঞান তোমাকে রক্ষা করে।", "category": "জ্ঞান" },
    { "id": "ali-006", "text": "মানুষ তার জিহ্বার নিচে লুকিয়ে থাকে।", "category": "আচরণ" },
    { "id": "ali-007", "text": "সত্য বল, যদিও তা তিক্ত হয়।", "category": "নৈতিকতা" },
    { "id": "ali-008", "text": "অহংকার মানুষকে ধ্বংস করে।", "category": "নৈতিকতা" },
    { "id": "ali-009", "text": "বন্ধুত্ব পরীক্ষা করো বিপদের সময়।", "category": "সম্পর্ক" },
    { "id": "ali-010", "text": "যে বেশি কথা বলে, সে বেশি ভুল করে।", "category": "আচরণ" },

    { "id": "ali-011", "text": "লোভ মানুষকে অন্ধ করে দেয়।", "category": "নৈতিকতা" },
    { "id": "ali-012", "text": "ক্ষমা হলো শ্রেষ্ঠ প্রতিশোধ।", "category": "নৈতিকতা" },
    { "id": "ali-013", "text": "মৃত্যু তোমার পিছু নিয়েছে, তাই সৎ পথে চলো।", "category": "আখিরাত" },
    { "id": "ali-014", "text": "নিজেকে ঠিক করো, পৃথিবী নিজে থেকেই ঠিক হয়ে যাবে।", "category": "জীবন" },
    { "id": "ali-015", "text": "যে কৃতজ্ঞ নয়, সে কোনোদিন সুখী হয় না।", "category": "নৈতিকতা" },
    { "id": "ali-016", "text": "হিংসা মানুষের ভালো কাজ নষ্ট করে।", "category": "নৈতিকতা" },
    { "id": "ali-017", "text": "ভালোবাসা এমন এক বন্ধন যা হৃদয়কে শক্ত করে।", "category": "ভালোবাসা" },
    { "id": "ali-018", "text": "সৎ মানুষের সঙ্গ গ্রহণ করো।", "category": "সম্পর্ক" },
    { "id": "ali-019", "text": "মিথ্যা মানুষকে লজ্জিত করে।", "category": "নৈতিকতা" },
    { "id": "ali-020", "text": "জ্ঞান ছাড়া কাজ অর্থহীন।", "category": "জ্ঞান" },

    { "id": "ali-021", "text": "দুনিয়া ক্ষণস্থায়ী, আখিরাত চিরস্থায়ী।", "category": "আখিরাত" },
    { "id": "ali-022", "text": "যে ধৈর্য ধারণ করে, সে সফল হয়।", "category": "ধৈর্য" },
    { "id": "ali-023", "text": "অন্যের দোষ দেখার আগে নিজের দোষ দেখো।", "category": "নৈতিকতা" },
    { "id": "ali-024", "text": "অতিরিক্ত হাসি হৃদয়কে কঠিন করে।", "category": "আচরণ" },
    { "id": "ali-025", "text": "সৎ কাজ মানুষকে সম্মানিত করে।", "category": "জীবন" },
    { "id": "ali-026", "text": "বুদ্ধিমান ব্যক্তি কম কথা বলে বেশি কাজ করে।", "category": "জ্ঞান" },
    { "id": "ali-027", "text": "ধন নয়, জ্ঞানই মানুষের আসল সম্পদ।", "category": "জ্ঞান" },
    { "id": "ali-028", "text": "অন্যের প্রতি দয়া দেখাও, আল্লাহ তোমার প্রতি দয়া করবেন।", "category": "ইমান" },
    { "id": "ali-029", "text": "নিজেকে ছোট মনে করো, অহংকার থেকে বাঁচবে।", "category": "নৈতিকতা" },
    { "id": "ali-030", "text": "সৎ পথই মানুষের প্রকৃত মুক্তি।", "category": "ইমান" },

    { "id": "ali-031", "text": "রাগ নিয়ন্ত্রণ করাই প্রকৃত শক্তি।", "category": "আচরণ" },
    { "id": "ali-032", "text": "যে আল্লাহকে ভয় করে, সে কাউকে ভয় করে না।", "category": "ইমান" },
    { "id": "ali-033", "text": "সময়কে মূল্য দাও, এটি আর ফিরে আসবে না।", "category": "জীবন" },
    { "id": "ali-034", "text": "অজ্ঞতা মানুষের সবচেয়ে বড় শত্রু।", "category": "জ্ঞান" },
    { "id": "ali-035", "text": "বন্ধুত্বে সততা সবচেয়ে গুরুত্বপূর্ণ।", "category": "সম্পর্ক" },
    { "id": "ali-036", "text": "যে নিজেকে নিয়ন্ত্রণ করতে পারে, সে সবকিছু জয় করতে পারে।", "category": "জীবন" },
    { "id": "ali-037", "text": "অপরের উপকার করো, সেটাই শ্রেষ্ঠ কাজ।", "category": "নৈতিকতা" },
    { "id": "ali-038", "text": "অহংকার জ্ঞানকে ধ্বংস করে।", "category": "নৈতিকতা" },
    { "id": "ali-039", "text": "দুনিয়ার ভালোবাসা হৃদয়কে অন্ধ করে।", "category": "আখিরাত" },
    { "id": "ali-040", "text": "সৎ চরিত্রই মানুষের আসল সৌন্দর্য।", "category": "নৈতিকতা" },

    { "id": "ali-041", "text": "শত্রুকেও ন্যায়ের সাথে আচরণ করো।", "category": "নৈতিকতা" },
    { "id": "ali-042", "text": "যে নিজের ভুল স্বীকার করে, সে জ্ঞানী।", "category": "জ্ঞান" },
    { "id": "ali-043", "text": "দুঃখ মানুষের হৃদয়কে শক্ত করে।", "category": "জীবন" },
    { "id": "ali-044", "text": "অন্যকে ক্ষমা করলে নিজেই শান্তি পাও।", "category": "নৈতিকতা" },
    { "id": "ali-045", "text": "সত্যের পথ কঠিন কিন্তু সুন্দর।", "category": "ইমান" },
    { "id": "ali-046", "text": "যে বেশি আশা করে, সে বেশি হতাশ হয়।", "category": "জীবন" },
    { "id": "ali-047", "text": "নেক আমলই আখিরাতে সঙ্গী হবে।", "category": "আখিরাত" },
    { "id": "ali-048", "text": "হিংসা আত্মাকে ধ্বংস করে।", "category": "নৈতিকতা" },
    { "id": "ali-049", "text": "সৎ মানুষ সবসময় সম্মান পায়।", "category": "জীবন" },
    { "id": "ali-050", "text": "আল্লাহর স্মরণেই হৃদয়ের শান্তি।", "category": "ইমান" }
  ]
}